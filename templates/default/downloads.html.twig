{% extends'layout.html.twig' %}

{% block title %}télémaintenance-utilitaires{% endblock %}

{% block body %}
    <div class="parallax-container">
        <div class="parallax"><img src="{{ asset('pictures/Logo_telechargement.png') }}" class="responsive-img" alt="Parallax"></div>
    </div>
    <div class="section light-grey">
        <div class="container">
            <div class="row center">
                <h3 class="header">Utilitaires</h3>
                <p class="grey-text text-darken-3 lighten-3">Dans cette section, vous trouverez des applications
                   utiles et pratiques pour voter usage de tout les jours</p>
                <!-- ROW 1 -->
                <div class="row">
                    {% for i in 1..10 %}
                    <div class="col s12 m4 l4">
{#                   LOOP FOREACH DOWNLOADS#}
                        <div class="card">
                            <div class="card-image">
                                <img src="https://i1.wp.com/www.viptuto.com/wp-content/uploads/2018/08/zz.jpg?w=1920&ssl=1">
                                <span class="card-title"></span>
                            </div>
                            <div class="card-content">
                                <p>VLC est un lecteur multimédia gratuit et libre et un système
                                    capable de lire la plupart des fichiers multimédias ainsi que
                                    des DVD, des CD Audio, des VCD, et divers protocoles de diffusion.
                                </p>
                            </div>
                            <div class="card-action">
                                <a href="https://get.videolan.org/vlc/3.0.6/win32/vlc-3.0.6-win32.exe">Télécharger VLC</a>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">
        $(document).ready(function(){
            $('.parallax').parallax();
        });
    </script>
{% endblock %}